{
  "manifest_version": 3,
  "name": "CHZZK-PureView",
  "short_name": "CHZZK-PureView",
  "description": "Clean-room CHZZK native 1080p workflow without the P2P/Grid install gate.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://chzzk.naver.com/*",
    "https://api.chzzk.naver.com/*",
    "https://nam.veta.naver.com/*"
  ],
  "permissions": [
    "declarativeNetRequest"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "veta_nofill",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "veta_gfp_nofill.json",
        "veta_vas_nofill.json",
        "veta_nac_nofill.json"
      ],
      "matches": [
        "https://chzzk.naver.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chzzk.naver.com/*"
      ],
      "js": [
        "content.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "CHZZK-PureView",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
